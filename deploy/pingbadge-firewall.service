[Unit]
Description=Allow inbound HTTP for PingBadge
Before=pingbadge.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/sh -c '/usr/sbin/iptables -C INPUT -p tcp -m state --state NEW -m tcp --dport 80 -j ACCEPT || /usr/sbin/iptables -I INPUT 5 -p tcp -m state --state NEW -m tcp --dport 80 -j ACCEPT'

[Install]
WantedBy=multi-user.target
