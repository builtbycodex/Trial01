[Unit]
Description=PingBadge uptime badge service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/pingbadge
Environment=PINGBADGE_HOST=0.0.0.0
Environment=PINGBADGE_PORT=80
Environment=PINGBADGE_DB=/opt/pingbadge/data/pingbadge.sqlite3
Environment=PINGBADGE_CHECK_INTERVAL=300
Environment=PINGBADGE_PUBLIC_ORIGIN=http://codex.y0u.se
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
ExecStart=/usr/bin/python3 /opt/pingbadge/app.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
